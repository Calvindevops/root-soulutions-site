      "credentials": {
        "sendInBlueApi": {
          "id": "tCBKxhdorIt59QKv",
          "name": "Brevo account"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://swfviswbxxyodktnbkve.supabase.co/rest/v1/workflow_log",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "supabaseApi",
        "sendHeaders": true,
        "headerParameters": {
