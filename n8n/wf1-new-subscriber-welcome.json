      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        460,
        400
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "sms-consent",
              "leftValue": "={{ $('Execute Workflow Trigger').item.json.body.data.sms_consent }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            },
            {
              "id": "has-phone",
              "leftValue": "={{ $('Execute Workflow Trigger').item.json.body.data.phone }}",
              "rightValue": "",
              "operator": {
                "type": "string",
                "operation": "isNotEmpty"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "twilio-welcome-sms",
      "name": "Twilio \u2014 Welcome SMS",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [
        680,
        320
      ],
      "parameters": {
        "from": "+18448202063",
        "to": "={{ $('Execute Workflow Trigger').item.json.body.data.phone }}",
        "message": "Root Soulutions: You're in the Soulution! Get 10% off your first order: lovecrafteatery.com/shop Use code WELCOME10. Reply STOP to opt out."
      },
      "credentials": {
        "twilioApi": {
          "id": "d83Oxb1xJ2lWmtZ1",
          "name": "Twilio SMS"
        }
      }
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nreturn items.map(item => {\n  const data = item.json.body.data;\n  return {\n    json: {\n      sender: { name: 'Root Soulutions', email: 'hello@rootsoulutions.com' },\n      to: [{ email: data.email }],\n      subject: 'Welcome to the Soulution',\n      htmlContent: \"<!DOCTYPE html><html><body style=\\\"font-family:sans-serif;background:#1a1a1a;color:#fff;padding:0;margin:0\\\"><div style=\\\"max-width:600px;margin:0 auto;padding:40px 32px\\\"><h1 style=\\\"color:#F5A623;font-size:32px;margin:0 0 16px\\\">Welcome to the Soulution</h1><p style=\\\"color:#ccc;font-size:16px;line-height:1.6\\\">You are officially part of the Root Soulutions family. We make bold, low-sodium, whole-food spice blends - no chemicals, no fillers, just real flavor crafted for people who care about what goes in their food.</p><h2 style=\\\"color:#F5A623;font-size:20px;margin:32px 0 8px\\\">Your Welcome Discount</h2><p style=\\\"color:#ccc;font-size:16px\\\">Use code <strong style=\\\"color:#fff;font-size:18px;letter-spacing:2px\\\">WELCOME10</strong> at checkout to save 10% on your first order.</p><a href=\\\"https://lovecrafteatery.com/shop\\\" style=\\\"display:inline-block;background:#e85c2a;color:#fff;font-weight:700;font-size:16px;padding:16px 32px;border-radius:50px;text-decoration:none;margin:24px 0\\\">Shop Now</a><p style=\\\"color:#888;font-size:13px;margin-top:40px;border-top:1px solid #333;padding-top:20px\\\">Root Soulutions - 1451 S Elm Eugene St, Greensboro, NC 27406<br/>Reply to this email to unsubscribe.</p></div></body></html>\"\n    }\n  };\n});"
      },
      "id": "code-build-welcome",
      "name": "Code \u2014 Build Welcome Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.brevo.com/v3/smtp/email",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "sendInBlueApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ $json }}",
        "options": {}
      },
      "id": "brevo-welcome-email",
