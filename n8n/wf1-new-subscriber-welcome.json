        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { \"workflow\": \"welcome\", \"action\": \"sent\", \"recipient\": $(\"Execute Workflow Trigger\").item.json.body.data.email, \"subject\": \"Welcome to the Soulution\", \"status\": \"ok\", \"details\": $(\"Execute Workflow Trigger\").item.json.body.data.sms_consent ? \"email+sms sent\" : \"email only\" } }}",
        "options": {}
      },
      "id": "supabase-log",
